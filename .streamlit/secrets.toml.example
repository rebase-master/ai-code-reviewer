# Copy to .streamlit/secrets.toml and fill in. NEVER commit the real file
# (it is git-ignored). Gemini free-tier key: https://aistudio.google.com/apikey
GEMINI_API_KEY = "your-gemini-api-key"

# Optional — override the model for any agent role.
# provider in {"gemini", "mock", "anthropic", "openai"}; the last two need
# their own key + an adapter. The reviewer defaults to a *different* model on
# purpose (independent, cross-model review).
[models]
# reviewer    = { provider = "gemini", model = "gemini-3.5-flash" }
# refactorer  = { provider = "gemini", model = "gemini-2.5-flash" }

# If you point a role at another provider, add its key (top level, not under [models]):
# ANTHROPIC_API_KEY = "..."
# OPENAI_API_KEY = "..."
